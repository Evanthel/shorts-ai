# Public browser variables. These are embedded in the Next.js client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only variables. Do not expose these through NEXT_PUBLIC_* or EXPO_PUBLIC_*.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
SUPABASE_SERVICE_ROLE_KEY=your-server-only-supabase-service-role-key
RATE_LIMIT_HASH_SECRET=your-random-server-only-rate-limit-hmac-secret
REQUIRE_PERSISTENT_RATE_LIMIT=false
