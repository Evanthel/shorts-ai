# Public browser variables. These are embedded in the Next.js client bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only variables. Do not expose these through NEXT_PUBLIC_* or EXPO_PUBLIC_*.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
SUPABASE_SERVICE_ROLE_KEY=your-server-only-supabase-service-role-key
RATE_LIMIT_HASH_SECRET=your-random-server-only-rate-limit-hmac-secret
REQUIRE_PERSISTENT_RATE_LIMIT=false

# Production recommendation rollout. The learned ranker still requires coverage gates.
FEATURE_COMMUTE_V2=true
FEATURE_OUTFIT_VARIANTS=true
FEATURE_POST_ACTIVITY_FEEDBACK=true
FEATURE_AI_INTENTS=true
FEATURE_ML_RANKER=false
FEATURE_ML_RANKER_PERCENT=0
RECOMMENDER_MODEL_JSON=
RECOMMENDER_COVERAGE_JSON=

# Required only by the first-party SWAOP export command.
SWAOP_PSEUDONYM_SECRET=your-random-export-only-hmac-secret
