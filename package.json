{
  "name": "shorts-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app features lib types tests packages/core",
    "test": "tsx --test tests/**/*.test.ts",
    "mobile:start": "npm --workspace @shorts-ai/mobile run start",
    "mobile:ios": "npm --workspace @shorts-ai/mobile run ios",
    "mobile:typecheck": "npm --workspace @shorts-ai/mobile run typecheck",
    "dataset:export": "tsx scripts/export-swaop.ts",
    "check": "npm run lint && npm run test && npm run build && npm run mobile:typecheck"
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@shorts-ai/core": "file:packages/core",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.31",
    "next": "^16.2.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.11",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "sharp@0.34.5": "0.35.3"
  }
}
